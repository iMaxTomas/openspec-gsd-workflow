{
  "name": "openspec-gsd-workflow",
  "version": "0.3.0",
  "description": "AI-assisted development workflow with automatic context management, spec-driven development, and git worktree isolation",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "test": "node tests/context-monitor.test.mjs",
    "test:integration": "node tests/integration.test.mjs",
    "lint": "shellcheck scripts/*.sh git-agent.sh",
    "validate": "node scripts/validate-config.mjs",
    "setup": "node scripts/setup.mjs",
    "ml:analyze": "node .opencode/scripts/ml-suggestions.mjs analyze",
    "ml:worktree": "node .opencode/scripts/ml-suggestions.mjs worktree",
    "predict": "node .opencode/scripts/predictive-context.mjs predict",
    "plan": "node .opencode/scripts/predictive-context.mjs plan",
    "perf:analyze": "node .opencode/scripts/performance-optimizer.mjs analyze",
    "perf:profile": "node .opencode/scripts/performance-optimizer.mjs profile",
    "perf:report": "node .opencode/scripts/performance-optimizer.mjs report"
  },
  "keywords": [
    "ai-assisted-development",
    "spec-driven-development",
    "context-management",
    "git-worktree",
    "openspec",
    "gsd",
    "claude-code",
    "workflow"
  ],
  "author": "Your Name",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iMaxTomas/openspec-gsd-workflow.git"
  },
  "bugs": {
    "url": "https://github.com/iMaxTomas/openspec-gsd-workflow/issues"
  },
  "homepage": "https://github.com/iMaxTomas/openspec-gsd-workflow#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {}
}
